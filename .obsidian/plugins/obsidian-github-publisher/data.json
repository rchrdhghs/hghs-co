{
  "github": {
    "branch": "main",
    "automaticallyMergePR": true,
    "tokenPath": "%configDir%/plugins/%pluginID%/env",
    "api": {
      "tiersForApi": "Github Free/Pro/Team (default)",
      "hostname": ""
    },
    "workflow": {
      "commitMessage": "publish: {{title}} [{{date}}]",
      "name": ""
    },
    "repo": "REPLACE_WITH_YOUR_REPO_NAME",
    "user": "REPLACE_WITH_YOUR_GITHUB_USERNAME"
  },
  "upload": {
    "behavior": "yaml",
    "defaultName": "content/posts",
    "rootFolder": "",
    "yamlFolderKey": "path",
    "frontmatterTitle": {
      "title": "title",
      "key": "title"
    },
    "replaceTitle": [],
    "replacePath": [],
    "autoclean": {
      "enable": false,
      "excluded": []
    },
    "folderNote": {
      "enable": false,
      "rename": "index"
    },
    "metadataExtractorPath": ""
  },
  "conversion": {
    "hardbreak": false,
    "dataview": false,
    "censorText": [],
    "tags": {
      "inline": false,
      "exclude": [],
      "fields": []
    },
    "links": {
      "internal": true,
      "unshared": true,
      "wiki": true,
      "slugify": "lower"
    }
  },
  "embed": {
    "attachments": true,
    "overrideAttachments": [],
    "keySendFile": [],
    "notes": false,
    "folder": "assets/images",
    "convertEmbedToLinks": "keep",
    "charConvert": "->",
    "unHandledObsidianExt": false,
    "sendSimpleLinks": true
  },
  "plugin": {
    "shareKey": "share",
    "fileMenu": true,
    "editorMenu": true,
    "excludedFolder": [
      ".obsidian",
      "templates",
      "_private"
    ],
    "copyLink": {
      "enable": false,
      "links": "",
      "removePart": [],
      "addCmd": false
    },
    "noticeError": true,
    "displayModalRepoEditing": false,
    "setShareKey": false
  }
}
